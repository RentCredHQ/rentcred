# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://rentcred:rentcred@localhost:5433/rentcred?schema=public"

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-characters-required"
JWT_EXPIRES_IN="7d"

# ============================================
# APPLICATION
# ============================================
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ============================================
# REDIS (for BullMQ and caching)
# ============================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ============================================
# PAYMENT - PAYSTACK
# ============================================
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."

# ============================================
# FILE STORAGE - CLOUDFLARE R2
# ============================================
# Setup: Cloudflare Dashboard → R2 → Create bucket → Manage R2 API Tokens
# Account ID is visible in the R2 overview page URL
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="rentcred-uploads"
# Enable "Public access" on the bucket to get this URL, or use a custom domain
# e.g. https://pub-xxxxxxxxxxxxxxxx.r2.dev  OR  https://uploads.rentcred.ng
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev"

# ============================================
# EMAIL - RESEND
# ============================================
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@rentcred.ng"

# ============================================
# SMS - TERMII (Optional)
# ============================================
SMS_PROVIDER_API_KEY=""
SMS_PROVIDER_SENDER_ID="RentCred"
TERMII_API_KEY=""
TERMII_SENDER_ID="RentCred"

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# SEED CONFIGURATION
# ============================================
ADMIN_EMAIL="admin@rentcred.ng"
ADMIN_PASSWORD="Admin123!"
# Set to 'true' to create demo data (development/staging only)
CREATE_DEMO_DATA="true"

# ============================================
# ERROR TRACKING (Optional)
# ============================================
SENTRY_DSN=""
